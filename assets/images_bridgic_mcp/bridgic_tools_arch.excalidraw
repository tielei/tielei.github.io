      "type": "text",
      "x": 2084.4366255095433,
      "y": 989.8318178148866,
      "width": 360.9276428222656,
      "height": 120,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
